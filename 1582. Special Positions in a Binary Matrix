function numSpecial(mat: number[][]): number {

    let sumX = new Array(mat.length).fill(0);
    let sumY = new Array(mat[0].length).fill(0);

    for (let i = 0; i < mat.length; i++) {
        for (let j = 0; j < mat[0].length; j++) {
            sumX[i] += mat[i][j];
            sumY[j] += mat[i][j];

        }
    }

    let ans = 0;

    for(let i = 0; i < mat.length; i ++){
        for(let j = 0; j < mat[0].length; j++){
            if(mat[i][j] == 1 && sumX[i] == 1 && sumY[j] == 1) ans++;
        }
    }
    return ans;
};
