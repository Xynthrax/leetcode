function closestTarget(words: string[], target: string, startIndex: number): number {

    const len = words.length;

    const map = new Map< string, number[]>();

    for( let [idx,word] of words.entries()){
        const temp : number[] = map.get(word) || [];

        temp.push(idx);
        map.set(word,temp)
        // console.log(temp, map)
    }

    // console.log(map);

    const indexesOfTheTargetWord = map.get(target);

    if(!indexesOfTheTargetWord) return -1;
    // console.log(indexesOfTheTargetWord)
    let ans = Infinity

    for(let [i,elm] of indexesOfTheTargetWord.entries()){
        let tmp : number;

        if( elm - startIndex > 0 ){
            tmp = Math.min( elm - startIndex , Math.abs( ( startIndex + len  ) - elm))
        }else{
            tmp = Math.min( startIndex - elm , Math.abs( ( elm + len  ) - startIndex))
        }
        // console.log(tmp)
        ans = Math.min( ans, tmp)

    }


    return ans;

};
